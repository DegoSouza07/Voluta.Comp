# --- Postgres ---
# Em produção (Railway/Render/Heroku), defina DATABASE_URL no lugar
# destas 6 variáveis — tem prioridade e as ignora quando presente.
# DATABASE_URL=postgres://user:pass@host:5432/dbname
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=voluta
DB_SYNC=false
DB_LOGGING=false
DB_SSL=false

# --- Redis / BullMQ ---
# Em produção, defina REDIS_URL no lugar destas 3 — mesma prioridade que
# o DATABASE_URL acima.
# REDIS_URL=redis://default:pass@host:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Auth ---
JWT_SECRET=troque-por-um-segredo-forte-em-producao
JWT_EXPIRES_IN=8h

# --- Object Storage (Supabase Storage / R2 / S3) ---
STORAGE_ENDPOINT=https://<project>.supabase.co/storage/v1/s3
STORAGE_REGION=auto
STORAGE_BUCKET=voluta-media
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_BASE_URL=https://<project>.supabase.co/storage/v1/object/public/voluta-media

# --- OpenAI ---
OPENAI_API_KEY=

# --- Notificações ---
SLACK_WEBHOOK_URL=

# --- PDF Rendering (Puppeteer) ---
# Deixe em branco pra usar o Chromium baixado pelo próprio pacote puppeteer.
# Em containers Docker que já têm Chromium do sistema instalado (mais leve),
# aponte pro binário: /usr/bin/chromium
PUPPETEER_EXECUTABLE_PATH=

# --- App ---
PORT=3000
CORS_ORIGIN=http://localhost:3001
